# AnyLogic MCP Server — environment variables
#
# These are set in the "env" block of .mcp.json, NOT in a .env file.
# This file exists only as a reference for what each variable does.

# Directory where generated .alp files are saved (required)
ALP_OUTPUT_DIR=/path/to/your/output/folder

# AnyLogic Cloud API key (optional — only needed for anylogic_upload_to_cloud)
# Get one at: https://cloud.anylogic.com/settings/api-keys
ANYLOGIC_API_KEY=your_api_key_here
